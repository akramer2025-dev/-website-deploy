rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // طلبات الانضمام: أي زائر يقدر يكتب، القراءة للجميع (الأدمن محلي)
    match /join_requests/{docId} {
      allow read, write: if true;
    }

    // بيانات الأدمن: قراءة وكتابة مفتوحة (الأمان عن طريق الـ admin password locally)
    match /admin_data/{docId} {
      allow read, write: if true;
    }

  }
}
