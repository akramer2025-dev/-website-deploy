rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // طلبات الانضمام: أي زائر يقدر يكتب، القراءة للجميع
    match /join_requests/{docId} {
      allow read, write: if true;
    }

    // بيانات الأدمن: قراءة وكتابة مفتوحة
    match /admin_data/{docId} {
      allow read, write: if true;
    }

    // المحاضرات: كل محاضرة doc مستقل — قراءة وكتابة مفتوحة
    match /lectures/{lecId} {
      allow read, write: if true;
    }

    // بيانات الموظفين: قراءة وكتابة مفتوحة
    match /employees/{employeeId} {
      allow read, write: if true;
    }

    // إعدادات الموقع: قراءة وكتابة مفتوحة
    match /settings/{settingId} {
      allow read, write: if true;
    }

  }
}
